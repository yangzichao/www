---
import type { MarkdownHeading } from 'astro';
import TocList from './TocList.astro';
import { tocHeadingsOf, shouldShowToc } from '../../lib/toc';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
---

{
  shouldShowToc(headings) && (
    <aside class="toc-rail" data-toc aria-label="Table of contents">
      <p class="toc-rail-label">On this page</p>
      <TocList headings={tocHeadingsOf(headings)} />
    </aside>
  )
}
