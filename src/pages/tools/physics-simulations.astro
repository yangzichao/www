---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tools/physics-simulation-lab.css';

const simulationTabs = [
  {
    id: 'double-pendulum',
    icon: 'ph-infinity',
    label: 'Double Pendulum',
    summary: 'Nonlinear motion',
  },
  {
    id: 'orbit-lab',
    icon: 'ph-planet',
    label: 'Orbit Lab',
    summary: 'Gravity and launch energy',
  },
  {
    id: 'wave-interference',
    icon: 'ph-wave-sine',
    label: 'Wave Interference',
    summary: 'Coherent sources',
  },
];
---

<BaseLayout
  title="Physics Simulation Lab - Zichao Yang"
  description="Three browser-based physics simulations: double pendulum chaos, orbital mechanics, and wave interference."
>
  <section class="physics-lab" data-physics-simulation-lab>
    <header class="physics-lab__header">
      <a href="/" class="physics-lab__home-link">
        <i class="ph ph-arrow-left" aria-hidden="true"></i>
        <span>Home</span>
      </a>

      <div class="physics-lab__title-block">
        <p class="physics-lab__eyebrow">Physics Simulation Lab</p>
        <h1>Three physics systems you can perturb directly.</h1>
        <p>
          A compact browser lab for nonlinear chaos, central-force orbits, and coherent-wave
          interference. The simulations run locally on canvas.
        </p>
      </div>
    </header>

    <nav class="physics-lab__tabs" aria-label="Physics simulation projects">
      {
        simulationTabs.map((tab, index) => (
          <button
            class={`physics-lab__tab ${index === 0 ? 'is-active' : ''}`}
            type="button"
            data-simulation-tab={tab.id}
            aria-controls={`panel-${tab.id}`}
            aria-selected={index === 0 ? 'true' : 'false'}
          >
            <i class={`ph ${tab.icon}`} aria-hidden="true"></i>
            <span>
              <strong>{tab.label}</strong>
              <small>{tab.summary}</small>
            </span>
          </button>
        ))
      }
    </nav>

    <div class="physics-lab__workspace">
      <article
        class="simulation-panel is-active"
        id="panel-double-pendulum"
        data-simulation-panel="double-pendulum"
      >
        <div class="simulation-panel__stage">
          <canvas
            class="simulation-canvas"
            width="900"
            height="520"
            data-double-pendulum-canvas
            aria-label="Double pendulum simulation canvas"></canvas>

          <div class="simulation-readouts" aria-label="Double pendulum readouts">
            <span>
              <small>Time</small>
              <strong data-double-readout="time">0.0 s</strong>
            </span>
            <span>
              <small>Energy</small>
              <strong data-double-readout="energy">0.00</strong>
            </span>
            <span>
              <small>Angle spread</small>
              <strong data-double-readout="spread">0 deg</strong>
            </span>
          </div>
        </div>

        <form class="simulation-controls" aria-label="Double pendulum controls">
          <div class="simulation-controls__header">
            <p>Project 01</p>
            <h2>Double Pendulum</h2>
          </div>

          <div class="simulation-controls__actions">
            <button class="simulation-button is-primary" type="button" data-double-action="toggle">
              <i class="ph ph-pause" aria-hidden="true"></i>
              <span>Pause</span>
            </button>
            <button class="simulation-button" type="button" data-double-action="reset">
              <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
              <span>Reset</span>
            </button>
          </div>

          <label class="simulation-toggle">
            <input type="checkbox" data-double-control="showTrail" checked />
            <span>
              <strong>Trace tip</strong>
              <small>Keep recent phase history visible.</small>
            </span>
          </label>

          <label class="simulation-range">
            <span>
              <strong>Gravity</strong>
              <output data-double-output="gravity">1.00x</output>
            </span>
            <input
              type="range"
              min="0.4"
              max="2.2"
              step="0.05"
              value="1"
              data-double-control="gravity"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Damping</strong>
              <output data-double-output="damping">0.02</output>
            </span>
            <input
              type="range"
              min="0"
              max="0.16"
              step="0.005"
              value="0.02"
              data-double-control="damping"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Upper angle</strong>
              <output data-double-output="upperAngle">120 deg</output>
            </span>
            <input
              type="range"
              min="-170"
              max="170"
              step="1"
              value="120"
              data-double-control="upperAngle"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Lower angle</strong>
              <output data-double-output="lowerAngle">-35 deg</output>
            </span>
            <input
              type="range"
              min="-170"
              max="170"
              step="1"
              value="-35"
              data-double-control="lowerAngle"
            />
          </label>
        </form>
      </article>

      <article
        class="simulation-panel"
        id="panel-orbit-lab"
        data-simulation-panel="orbit-lab"
      >
        <div class="simulation-panel__stage">
          <canvas
            class="simulation-canvas"
            width="900"
            height="520"
            data-orbit-canvas
            aria-label="Orbital mechanics simulation canvas"></canvas>

          <div class="simulation-readouts" aria-label="Orbit lab readouts">
            <span>
              <small>Orbit class</small>
              <strong data-orbit-readout="classification">Bound</strong>
            </span>
            <span>
              <small>Radius</small>
              <strong data-orbit-readout="radius">180 px</strong>
            </span>
            <span>
              <small>Energy</small>
              <strong data-orbit-readout="energy">0.00</strong>
            </span>
          </div>
        </div>

        <form class="simulation-controls" aria-label="Orbit lab controls">
          <div class="simulation-controls__header">
            <p>Project 02</p>
            <h2>Orbit Lab</h2>
          </div>

          <div class="simulation-controls__actions">
            <button class="simulation-button is-primary" type="button" data-orbit-action="toggle">
              <i class="ph ph-pause" aria-hidden="true"></i>
              <span>Pause</span>
            </button>
            <button class="simulation-button" type="button" data-orbit-action="reset">
              <i class="ph ph-crosshair" aria-hidden="true"></i>
              <span>Launch</span>
            </button>
          </div>

          <div class="simulation-presets" aria-label="Orbit presets">
            <button type="button" data-orbit-preset="circle">Circle</button>
            <button type="button" data-orbit-preset="ellipse">Ellipse</button>
            <button type="button" data-orbit-preset="escape">Escape</button>
          </div>

          <label class="simulation-toggle">
            <input type="checkbox" data-orbit-control="showTrail" checked />
            <span>
              <strong>Trace path</strong>
              <small>Leave a trajectory behind the body.</small>
            </span>
          </label>

          <label class="simulation-range">
            <span>
              <strong>Central mass</strong>
              <output data-orbit-output="centralMass">1.00x</output>
            </span>
            <input
              type="range"
              min="0.4"
              max="2.4"
              step="0.05"
              value="1"
              data-orbit-control="centralMass"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Launch radius</strong>
              <output data-orbit-output="launchRadius">180 px</output>
            </span>
            <input
              type="range"
              min="120"
              max="255"
              step="1"
              value="180"
              data-orbit-control="launchRadius"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Launch speed</strong>
              <output data-orbit-output="launchSpeed">1.00x</output>
            </span>
            <input
              type="range"
              min="0.55"
              max="1.55"
              step="0.01"
              value="1"
              data-orbit-control="launchSpeed"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Launch angle</strong>
              <output data-orbit-output="launchAngle">90 deg</output>
            </span>
            <input
              type="range"
              min="45"
              max="135"
              step="1"
              value="90"
              data-orbit-control="launchAngle"
            />
          </label>
        </form>
      </article>

      <article
        class="simulation-panel"
        id="panel-wave-interference"
        data-simulation-panel="wave-interference"
      >
        <div class="simulation-panel__stage">
          <canvas
            class="simulation-canvas"
            width="900"
            height="520"
            data-wave-canvas
            aria-label="Wave interference simulation canvas"></canvas>

          <div class="simulation-readouts" aria-label="Wave interference readouts">
            <span>
              <small>Path diff</small>
              <strong data-wave-readout="pathDifference">0 px</strong>
            </span>
            <span>
              <small>Sample field</small>
              <strong data-wave-readout="field">0.00</strong>
            </span>
            <span>
              <small>Fringe scale</small>
              <strong data-wave-readout="fringeScale">48 px</strong>
            </span>
          </div>
        </div>

        <form class="simulation-controls" aria-label="Wave interference controls">
          <div class="simulation-controls__header">
            <p>Project 03</p>
            <h2>Wave Interference</h2>
          </div>

          <div class="simulation-controls__actions">
            <button class="simulation-button is-primary" type="button" data-wave-action="toggle">
              <i class="ph ph-pause" aria-hidden="true"></i>
              <span>Pause</span>
            </button>
            <button class="simulation-button" type="button" data-wave-action="reset">
              <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
              <span>Reset</span>
            </button>
          </div>

          <label class="simulation-range">
            <span>
              <strong>Wavelength</strong>
              <output data-wave-output="wavelength">48 px</output>
            </span>
            <input
              type="range"
              min="24"
              max="88"
              step="1"
              value="48"
              data-wave-control="wavelength"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Source gap</strong>
              <output data-wave-output="sourceSeparation">160 px</output>
            </span>
            <input
              type="range"
              min="48"
              max="260"
              step="1"
              value="160"
              data-wave-control="sourceSeparation"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Phase offset</strong>
              <output data-wave-output="phaseOffset">0 deg</output>
            </span>
            <input
              type="range"
              min="-180"
              max="180"
              step="1"
              value="0"
              data-wave-control="phaseOffset"
            />
          </label>

          <label class="simulation-range">
            <span>
              <strong>Falloff</strong>
              <output data-wave-output="falloff">0.006</output>
            </span>
            <input
              type="range"
              min="0.001"
              max="0.014"
              step="0.001"
              value="0.006"
              data-wave-control="falloff"
            />
          </label>
        </form>
      </article>
    </div>
  </section>

  <script>
    import { initPhysicsSimulationLab } from '../../scripts/physics-simulation-lab/physics-simulation-lab-main';
    initPhysicsSimulationLab();
  </script>
</BaseLayout>
