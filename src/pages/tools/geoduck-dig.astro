---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tools/geoduck-dig.css';
---

<BaseLayout
  title="Geoduck Dig | Zichao Yang"
  description="A browser game about PNW geoduck digging: low tide, siphon shows, horse clam decoys, cave-ins, and hand tools."
>
  <section class="geoduck-page" data-geoduck-game>
    <nav class="geoduck-nav" aria-label="Game navigation">
      <a class="geoduck-back-link" href="/">
        <i class="ph ph-arrow-left" aria-hidden="true"></i>
        Home
      </a>
      <span class="geoduck-badge">PNW low tide simulation</span>
    </nav>

    <header class="geoduck-hero">
      <h1 class="geoduck-title">Geoduck Dig</h1>
      <p class="geoduck-subtitle">
        Read the siphon shows, manage the rising tide, avoid horse clam decoys, brace the
        hole, and leave the flat clean.
      </p>
    </header>

    <div class="geoduck-game">
      <div class="geoduck-status-strip" aria-label="Dig status">
        <div class="geoduck-meter">
          <span class="geoduck-meter-label">Tide</span>
          <span class="geoduck-meter-value" data-tide-value>-2.8 ft</span>
          <span class="geoduck-meter-note" data-tide-status>diggable</span>
        </div>
        <div class="geoduck-meter">
          <span class="geoduck-meter-label">Energy</span>
          <span class="geoduck-meter-value" data-energy-value>100</span>
          <div class="geoduck-energy-track" aria-hidden="true">
            <div class="geoduck-energy-bar" data-energy-bar></div>
          </div>
        </div>
        <div class="geoduck-meter">
          <span class="geoduck-meter-label">Bag</span>
          <span class="geoduck-meter-value" data-limit-value>0/1</span>
          <span class="geoduck-meter-note">geoduck</span>
        </div>
        <div class="geoduck-meter">
          <span class="geoduck-meter-label">Open holes</span>
          <span class="geoduck-meter-value" data-holes-value>0</span>
          <span class="geoduck-meter-note">refill before leaving</span>
        </div>
        <div class="geoduck-meter">
          <span class="geoduck-meter-label">Score</span>
          <span class="geoduck-meter-value" data-score-value>0</span>
          <span class="geoduck-meter-note">clean work pays</span>
        </div>
      </div>

      <div class="geoduck-playfield">
        <div class="geoduck-beach-panel">
          <canvas
            class="geoduck-beach-canvas"
            data-beach-canvas
            aria-label="Clickable beach flat with clam shows"
          ></canvas>
          <div class="geoduck-outcome" data-outcome data-tone="normal">Low tide active</div>
        </div>

        <aside class="geoduck-side-panel" aria-label="Dig controls">
          <section class="geoduck-selected">
            <h2 class="geoduck-panel-title">Selected show</h2>
            <div class="geoduck-selected-title" data-selected-title>No show selected</div>
            <p class="geoduck-selected-clue" data-selected-clue>
              Click a dimple, keyhole, or siphon mark on the beach.
            </p>
            <div class="geoduck-selected-depth" data-selected-depth>0.0 ft dug</div>
            <div class="geoduck-progress-track" aria-hidden="true">
              <div class="geoduck-progress-bar" data-selected-progress></div>
            </div>
          </section>

          <section class="geoduck-tools">
            <h2 class="geoduck-panel-title">Tools</h2>
            <div class="geoduck-tool-grid">
              <button class="geoduck-tool-button is-active" type="button" data-tool="probe">
                <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
                <span>Probe</span>
              </button>
              <button class="geoduck-tool-button" type="button" data-tool="tube">
                <i class="ph ph-circle-dashed" aria-hidden="true"></i>
                <span>Tube</span>
              </button>
              <button class="geoduck-tool-button" type="button" data-tool="shovel">
                <i class="ph ph-shovel" aria-hidden="true"></i>
                <span>Shovel</span>
              </button>
              <button class="geoduck-tool-button" type="button" data-tool="hand">
                <i class="ph ph-hand-palm" aria-hidden="true"></i>
                <span>Hand</span>
              </button>
              <button class="geoduck-tool-button" type="button" data-tool="refill">
                <i class="ph ph-arrow-arc-left" aria-hidden="true"></i>
                <span>Refill</span>
              </button>
            </div>
            <button class="geoduck-apply-button" type="button" data-apply-tool>Use Probe</button>
            <button class="geoduck-reset-button" type="button" data-reset-game>New Tide</button>
          </section>

          <section class="geoduck-log">
            <h2 class="geoduck-panel-title">Field log</h2>
            <ol class="geoduck-log-list" data-log-list></ol>
          </section>
        </aside>
      </div>
    </div>
  </section>

  <script>
    import { initGeoduckDigGame } from '../../scripts/geoduck-dig/geoduck-dig-main';

    initGeoduckDigGame();
  </script>
</BaseLayout>
