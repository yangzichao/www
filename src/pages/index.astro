---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import WorkCard from '../components/WorkCard.astro';
import Footer from '../components/Footer.astro';
import { siteData } from '../data/site';
---

<BaseLayout>
  <Header profile={siteData.profile} />

  <section>
    <h2 class="section-title" data-depth-reveal>Public Interface</h2>
    <div class="work-grid" data-depth-stagger data-scroll-tilt>
      {
        siteData.items.map((item) => (
          <div class="work-grid-item" data-depth-reveal>
            <WorkCard item={item} />
          </div>
        ))
      }
    </div>
  </section>

  <Footer />
</BaseLayout>
