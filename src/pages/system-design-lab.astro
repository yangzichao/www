---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdTrackingConstraintLab from '../components/system-design-lab/AdTrackingConstraintLab.astro';
import SystemDesignConstraintLab from '../components/system-design-lab/SystemDesignConstraintLab.astro';
import { systemDesignLabDefinitions } from '../scripts/system-design-lab/lab-definitions';
---

<BaseLayout
  title="System Design Lab | Zichao Yang"
  description="Constraint-driven system design playgrounds for ad tracking, Google Docs, Online Judge, and rate limiter designs."
>
  <nav class="system-lab-page-nav" aria-label="System Design Lab navigation">
    <a href="/">Home</a>
    <a href="/blog/">Blog</a>
    <a href="#ad-tracking">Ad Tracking</a>
    <a href="#google-docs">Google Docs</a>
    <a href="#leetcode-online-judge">Online Judge</a>
    <a href="#rate-limiter">Rate Limiter</a>
  </nav>

  <AdTrackingConstraintLab />

  {systemDesignLabDefinitions.map((lab) => <SystemDesignConstraintLab lab={lab} />)}
</BaseLayout>
