---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import 'katex/dist/katex.min.css';
import '../styles/post.css';

interface Props {
  frontmatter: CollectionEntry<'blog'>['data'];
}

const { frontmatter } = Astro.props;

// Use UTC so a frontmatter date like `2026-05-02` (parsed as midnight
// UTC by the YAML loader) doesn't shift to the previous day in any
// negative-offset timezone during build.
const formattedDate = frontmatter.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const isoDate = frontmatter.date.toISOString();
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description ?? frontmatter.title}
>
  <article class="prose prose-lg post-article">
    <header class="not-prose post-header">
      <h1 class="post-title">{frontmatter.title}</h1>
      <div class="post-meta">
        <time datetime={isoDate}>{formattedDate}</time>
        {frontmatter.venue && <span class="post-meta-separator">·</span>}
        {frontmatter.venue && <span class="post-venue">{frontmatter.venue}</span>}
      </div>
      {
        frontmatter.tags.length > 0 && (
          <ul class="post-tags">
            {frontmatter.tags.map((tag) => (
              <li class="post-tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </header>
    <slot />
  </article>

  <script slot="body-end" is:inline>
    // Lazy-load mermaid only on pages that contain a diagram. The
    // `remarkMermaidToPre` plugin emits `<pre class="mermaid">` during
    // the markdown build, so a single querySelector is enough to
    // detect whether this page actually needs the renderer.
    if (document.querySelector('pre.mermaid')) {
      import('https://esm.sh/mermaid@11')
        .then(({ default: mermaid }) => {
          mermaid.initialize({ startOnLoad: false, theme: 'default' });
          return mermaid.run({ querySelector: 'pre.mermaid' });
        })
        .catch((error) => {
          console.error('Failed to initialize Mermaid:', error);
        });
    }
  </script>
</BaseLayout>

<style>
  /* The article body is serif; keep the title and meta on Inter so the
     masthead matches the homepage. */
  .post-header {
    font-family: var(--font-stack);
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0 0 0.85rem;
    color: var(--color-text-main, #111111);
    text-wrap: balance;
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted, #666666);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .post-meta-separator {
    opacity: 0.5;
  }

  .post-venue {
    font-style: italic;
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    background: #f3f3f3;
    border-radius: 4px;
    color: var(--color-text-muted, #666666);
  }
</style>
