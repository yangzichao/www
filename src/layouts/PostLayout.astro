---
import BaseLayout from './BaseLayout.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import type { CollectionEntry } from 'astro:content';
import { getPublishedPosts, groupByCategory } from '../lib/posts';
import 'katex/dist/katex.min.css';
import '../styles/post.css';
import '../styles/blog-layout.css';
import '../styles/print.css';

interface Props {
  frontmatter: CollectionEntry<'blog'>['data'];
  id: string;
}

const { frontmatter, id } = Astro.props;

const groups = groupByCategory(await getPublishedPosts());

// Use UTC so a frontmatter date like `2026-05-02` (parsed as midnight
// UTC by the YAML loader) doesn't shift to the previous day in any
// negative-offset timezone during build.
const formattedDate = frontmatter.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const isoDate = frontmatter.date.toISOString();
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description ?? frontmatter.title}
>
  <div class="blog-layout">
    <BlogSidebar groups={groups} currentId={id} />
    <div class="blog-main">
      <article class="prose prose-lg post-article">
        <header class="not-prose post-header">
          <button
            type="button"
            class="pdf-download"
            aria-label="Download this post as PDF"
            onclick="window.print()"
          >
            <i class="ph ph-file-pdf" aria-hidden="true"></i>
            <span>Download PDF</span>
          </button>
          <h1 class="post-title">{frontmatter.title}</h1>
          <div class="post-meta">
            <time datetime={isoDate}>{formattedDate}</time>
            {frontmatter.venue && <span class="post-meta-separator">·</span>}
            {frontmatter.venue && <span class="post-venue">{frontmatter.venue}</span>}
          </div>
          {
            frontmatter.tags.length > 0 && (
              <ul class="post-tags">
                {frontmatter.tags.map((tag) => (
                  <li class="post-tag">{tag}</li>
                ))}
              </ul>
            )
          }
        </header>
        <slot />
      </article>
    </div>
  </div>

  <script slot="body-end" is:inline>
    // Lazy-load mermaid only on pages that contain a diagram. The
    // `remarkMermaidToPre` plugin emits `<pre class="mermaid">` during
    // the markdown build, so a single querySelector is enough to
    // detect whether this page actually needs the renderer.
    if (document.querySelector('pre.mermaid')) {
      import('https://esm.sh/mermaid@11')
        .then(({ default: mermaid }) => {
          // `base` theme + explicit variables so diagrams match the
          // blog's light, monochrome editorial palette (Inter, near-black
          // text, soft off-white nodes, muted gray edges) instead of
          // Mermaid's stock lavender-on-navy default.
          mermaid.initialize({
            startOnLoad: false,
            theme: 'base',
            fontFamily:
              '"Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif',
            themeVariables: {
              background: '#ffffff',
              primaryColor: '#f6f6f4',
              mainBkg: '#f6f6f4',
              primaryBorderColor: '#d3d3cd',
              nodeBorder: '#d3d3cd',
              primaryTextColor: '#111111',
              nodeTextColor: '#111111',
              lineColor: '#8c8c86',
              secondaryColor: '#efefec',
              tertiaryColor: '#fafafa',
              clusterBkg: '#ffffff',
              clusterBorder: '#e5e5e5',
              titleColor: '#0b0d0f',
              edgeLabelBackground: '#ffffff',
              fontSize: '15px',
            },
          });
          return mermaid.run({ querySelector: 'pre.mermaid' });
        })
        .catch((error) => {
          console.error('Failed to initialize Mermaid:', error);
        });
    }
  </script>
</BaseLayout>

<style>
  /* The article body is serif; keep the title and meta on Inter so the
     masthead matches the homepage. */
  .post-header {
    position: relative;
    font-family: var(--font-stack);
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }

  /* One-click "Save as PDF" — anchored top-right of the header, clear
     of the title. Hidden in print via styles/print.css. */
  .pdf-download {
    position: absolute;
    top: 0;
    right: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    font-family: var(--font-stack);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted, #666666);
    background: var(--color-background, #ffffff);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 999px;
    cursor: pointer;
    transition:
      color var(--transition, 0.15s ease),
      border-color var(--transition, 0.15s ease),
      background var(--transition, 0.15s ease);
  }

  .pdf-download:hover {
    color: var(--color-text-main, #111111);
    border-color: var(--color-text-muted, #999999);
    background: var(--color-card-hover, #f6f6f4);
  }

  .pdf-download i {
    font-size: 1rem;
    line-height: 1;
  }

  /* On narrow screens the floating "Contents" toggle sits top-left;
     keep the PDF button from colliding with a long wrapped title by
     letting it sit on its own line above the title. */
  @media (max-width: 600px) {
    .pdf-download {
      position: static;
      margin-bottom: 1rem;
    }

    .pdf-download span {
      display: inline;
    }
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0 0 0.85rem;
    color: var(--color-text-main, #111111);
    text-wrap: balance;
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted, #666666);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .post-meta-separator {
    opacity: 0.5;
  }

  .post-venue {
    font-style: italic;
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    background: #f3f3f3;
    border-radius: 4px;
    color: var(--color-text-muted, #666666);
  }
</style>
